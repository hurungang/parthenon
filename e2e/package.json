{
  "name": "parthenon-e2e",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test --config=playwright.dev.config.ts",
    "test:e2e:auth-required": "playwright test tests/auth-required --config=playwright.dev.config.ts --workers=1",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.47.0",
    "wait-on": "^8.0.0"
  }
}
