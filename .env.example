# ============================================================
# Parthenon — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in the values for your
# deployment.  Variables prefixed with TELEMETRY__ configure
# the telemetry subsystem (nested Pydantic model).
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME="Parthenon AI Harness"
ENVIRONMENT=development            # development | test | production
DEBUG=false

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://parthenon:parthenon@localhost:5432/parthenon

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Auth / OIDC
# ------------------------------------------------------------
OIDC_PROVIDER_URL=http://localhost:8082/realms/parthenon
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=RS256
JWT_AUDIENCE=parthenon

# ------------------------------------------------------------
# Credential Vault (AES-256 — must be exactly 32 bytes)
# ------------------------------------------------------------
CREDENTIAL_VAULT_KEY=change-me-32-byte-key-for-aes256!

# ============================================================
# Telemetry (TELEMETRY__* env vars override TelemetrySettings)
# ============================================================

# Active export targets (comma-separated list when using env vars).
# Supported: console, file, otlp, logfire, custom
# Default: otlp
# TELEMETRY__EXPORTERS='["otlp"]'

# Signal enable flags
# Type: bool | Default: true
# TELEMETRY__TRACES_ENABLED=true
# TELEMETRY__METRICS_ENABLED=true
# TELEMETRY__LOGS_ENABLED=true

# Service name attached to all OTEL spans / metrics / logs
# Type: str | Default: "parthenon-api"
# TELEMETRY__SERVICE_NAME=parthenon-api

# ── OTLP exporter ────────────────────────────────────────────
# TELEMETRY__OTLP__ENDPOINT=http://localhost:4317
# TELEMETRY__OTLP__PROTOCOL=grpc         # grpc | http
# TELEMETRY__OTLP__INSECURE=true

# ── File exporter ─────────────────────────────────────────────
# TELEMETRY__FILE__PATH=logs/otel.log
# TELEMETRY__FILE__MAX_BYTES=10485760    # 10 MB
# TELEMETRY__FILE__BACKUP_COUNT=5

# ── Logfire exporter ──────────────────────────────────────────
# Required when "logfire" is in TELEMETRY__EXPORTERS.
# Skipped with a warning if absent.
# TELEMETRY__LOGFIRE__TOKEN=your-logfire-project-token

# ── Custom endpoint exporter ──────────────────────────────────
# Required when "custom" is in TELEMETRY__EXPORTERS.
# TELEMETRY__CUSTOM__ENDPOINT=http://localhost:4318

# ── Per-component log levels ──────────────────────────────────
# JSON object mapping logger name → level string.
# "root" maps to the root Python logger.
# Valid levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
# TELEMETRY__LOG_LEVELS='{"root":"INFO","app.services":"DEBUG"}'

# ============================================================
# Frontend (Vite)
# ============================================================
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/ws
VITE_OIDC_AUTHORITY=http://localhost:8082/realms/parthenon
VITE_OIDC_CLIENT_ID=parthenon-api-ui
