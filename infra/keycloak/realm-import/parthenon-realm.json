{
  "realm": "parthenon",
  "displayName": "Parthenon",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "parthenon-api",
      "name": "Parthenon API",
      "description": "Confidential client for the Parthenon backend API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": [],
      "webOrigins": []
    },
    {
      "clientId": "parthenon-api-ui",
      "name": "Parthenon UI",
      "description": "Public client for the Parthenon frontend (Authorization Code + PKCE)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:4173/*",
        "http://localhost/*",
        "https://*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:4173",
        "http://localhost",
        "+"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Platform administrator with full access"
      },
      {
        "name": "user",
        "description": "Standard platform user"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@parthenon.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "user"],
      "groups": []
    },
    {
      "username": "testuser",
      "email": "testuser@parthenon.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testuser",
          "temporary": false
        }
      ],
      "realmRoles": ["user"],
      "groups": []
    }
  ]
}
